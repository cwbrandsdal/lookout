{
  "name": "lookout",
  "private": true,
  "version": "0.1.0",
  "productName": "Lookout",
  "author": "Christopher Brandsdal",
  "description": "Lookout desktop workspace organizer for multi-terminal project spaces.",
  "main": "dist-electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "run-p dev:renderer dev:electron:build dev:electron",
    "dev:renderer": "vite",
    "dev:electron:build": "node ./scripts/build-electron.mjs --watch",
    "dev:electron": "node ./scripts/dev-electron.mjs",
    "build": "tsc -b && tsc -p tsconfig.electron.json --noEmit && vite build && node ./scripts/build-electron.mjs",
    "dist:win": "npm run build && electron-builder --win nsis",
    "release:win": "npm run build && electron-builder --win nsis --publish always",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "electron ."
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "electron-updater": "^6.8.3",
    "lucide-react": "^1.0.1",
    "node-pty": "^1.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "npm-run-all": "^4.1.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "no.cwb.lookout",
    "productName": "Lookout",
    "directories": {
      "output": "release"
    },
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "files": [
      "dist/**",
      "dist-electron/**",
      "node_modules/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "public/app-icon.ico",
        "to": "app-icon.ico"
      }
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "win": {
      "icon": "public/app-icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Lookout-Setup-${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "cwbrandsdal",
        "repo": "lookout"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Lookout"
    }
  }
}
